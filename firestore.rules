rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Business collections: single-tenant app behind login — any authenticated
    // user may read/write, mirroring the original Base44 admin/user model.
    match /monitoredAssets/{docId} {
      allow read, write: if isSignedIn();
    }

    match /assetStates/{docId} {
      allow read, write: if isSignedIn();
    }

    match /signalEvents/{docId} {
      allow read, write: if isSignedIn();
    }

    match /tradeOperations/{docId} {
      allow read, write: if isSignedIn();
    }

    match /priceAlerts/{docId} {
      allow read, write: if isSignedIn();
    }

    match /systemLogs/{docId} {
      allow read, write: if isSignedIn();
    }

    // User profiles: a user may read/create their own profile, but cannot
    // grant themselves the admin role or edit anyone else's profile.
    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.role == 'user';
      allow update: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.role == resource.data.role;
    }

    // Strategy Reviewer chat: a user may read/create their own conversations,
    // but messages are only ever written by the strategyReviewerChat Cloud
    // Function (Admin SDK bypasses these rules) so nobody can spoof replies.
    match /agentConversations/{convId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && get(/databases/$(database)/documents/agentConversations/$(convId)).data.user_id == request.auth.uid;
        allow write: if false;
      }
    }

    // Telegram delivery config: only the chat_id destination lives here (the
    // bot token is an app-level Cloud Functions secret, never stored per-user).
    match /telegramConfig/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
